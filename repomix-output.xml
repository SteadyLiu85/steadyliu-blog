                  <td className="p-6 text-right">
                    <div className="flex items-center justify-end gap-4">
                      <Link 
                        to={`/edit/${post._id}`}
                        className="text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                        title="编辑文章"
                      >
